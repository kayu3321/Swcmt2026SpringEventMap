rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /eventApplications/{document=**} {
      allow read, write: if false;
    }

    match /eventMapCongestionItems/{document} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]) &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.category == resource.data.category &&
        request.resource.data.x == resource.data.x &&
        request.resource.data.y == resource.data.y &&
        request.resource.data.sortOrder == resource.data.sortOrder &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ["smooth", "normal", "busy"]
      );
    }
  }
}
